  .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .home-mix-card-image, .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .card-image-backlayer1, .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .card-image-backlayer2 {
    grid-area: 1/1;
  }
  .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .home-mix-card-image {
    height: 17rem;
    width: 17rem;
    z-index: 20;
    border-radius: 0.725rem;
    box-shadow: 0 -1rem 1rem -1.3rem rgba(0, 0, 0, 0.5);
  }
  .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .card-image-backlayer1 {
    background-color: #DD138B;
    height: 17rem;
    width: 15.4rem;
    z-index: 10;
    border-radius: 0.725rem;
    transform: translateY(-0.6rem);
    box-shadow: 0 -1rem 1rem -1.7rem rgba(0, 0, 0, 0.5);
  }
  .home-mix-card-container.chuckberrydarkpink .home-mix-card-image-container .card-image-backlayer2 {
    background-color: #DD138B;
    height: 17rem;
    width: 13.3rem;
    z-index: 1;
    border-radius: 0.725rem;
    transform: translateY(-1rem);
  }
}
.home-mix-card-list {
  display: flex;
  column-gap: 0.9rem;
  margin-bottom: 3rem;
  max-width: 94vw;
  flex-wrap: nowrap;
  overflow-x: hidden;
}

@media (min-width: 500px) {
  .home-mix-card-list {
    display: flex;
    margin-bottom: 3rem;
    column-gap: 1.1rem;
    flex-wrap: nowrap;
    overflow-x: hidden;
  }
}

.hide-desktop {
  display: block;
}
@media (min-width: 768px) {
  .hide-desktop {
    display: none !important;
  }
}

@media (max-width: 767px) {
  .hide-mobile {
    display: none !important;
  }
}

main {
  color: #E0E0E0;
  font-family: #ffffff;
}

.now-playing {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 1.5rem;
  position: relative;
  z-index: 0;
  overflow: hidden;
  background: white;
}

.songpage-wrapper {
  width: 100%;
  max-width: 100rem;
}
@media (max-width: 767px) {
  .songpage-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
}

.mobile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem 0 1.5rem;
}
.mobile-header .icon-btn img {
  width: 2.8rem;
  height: auto;
  display: block;
}
.mobile-header .mobile-header-center {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.mobile-header .mobile-header-text {
  font-size: 1.2rem;
  font-weight: 600;
  color: #ffffff;
}
.mobile-header .album-icon {
  width: 1.8rem;
  height: 1.8rem;
}

.track-header {
  display: flex;
  align-items: flex-start;
  gap: 4rem;
  padding-top: 2rem;
}
@media (max-width: 767px) {
  .track-header {
    flex-direction: column;
    gap: 0;
    padding-top: 0;
  }
}

@media (max-width: 767px) {
  .album-pic {
    width: 100%;
  }
}
.album-pic img {
  width: 100%;
  max-width: 50rem;
  border-radius: 0.8rem;
  display: block;
}

.track-info {
  width: 100%;
  padding: 1rem 0.3rem;
}
.track-info .track-title {
  font-size: 2rem;
  font-weight: 700;
  background: linear-gradient(90deg, #DBDBDB, #30353E);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.2;
  margin-bottom: 0.4rem;
}
.track-info .track-title2 {
  font-size: 1.5rem;
  font-weight: 500;
  color: #b3b3b3;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  color: #898989;
  margin: 15px 0;
  font-size: 0.9rem;
}
.info-row .info-icon {
  width: 16px;
  vertical-align: middle;
  margin-right: 4px;
}
.info-row .dot::before {
  content: "•";
  padding: 0 5px;
}

.icon-bar {
  list-style: none;
  display: flex;
  gap: 20px;
  margin: 25px 0;
  padding: 0;
}
.icon-bar .icon-btn img {
  width: 24px;
  opacity: 0.7;
  transition: opacity 0.2s;
}
.icon-bar .icon-btn img:hover {
  opacity: 1;
}

.genres {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 20px;
  padding: 0;
}
.genres .genre {
  background: rgba(255, 255, 255, 0.1);
  padding: 6px 15px;
  border-radius: 20px;
  font-size: 0.8rem;
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.artist-list {
  list-style: none;
  margin-top: 30px;
  padding: 0;
}
.artist-list .sub-artist {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 15px;
}
.artist-list .sub-artist .img-subartist {
  width: 45px;
  height: 45px;
  border-radius: 50%;
  object-fit: cover;
}
.artist-list .sub-artist .name {
  font-weight: 600;
  font-size: 0.95rem;
  color: #ffffff;
}
.artist-list .sub-artist .role {
  color: #b3b3b3;
  font-size: 0.8rem;
}

.mobile-track-info {
  padding: 1.6rem 0 0.4rem;
}
.mobile-track-info .mobile-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.mobile-track-info .mobile-titles {
  flex: 1;
  min-width: 0;
}
.mobile-track-info .track-title {
  font-size: 1.8rem;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 0.2rem;
}
.mobile-track-info .track-title2 {
  font-size: 1.4rem;
  font-weight: 400;
  color: #b3b3b3;
}
.mobile-track-info .mobile-actions {
  display: flex;
  gap: 0.8rem;
  flex-shrink: 0;
}
.mobile-track-info .mobile-actions .icon-btn img {
  width: 3.2rem;
  height: 3.2rem;
  display: block;
}

.player__progress {
  margin-top: 2rem;
}
@media (max-width: 767px) {
  .player__progress {
    margin-top: 1.6rem;
  }
}

.progress-bar {
  flex: 1;
  height: 0.3rem;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 10rem;
  position: relative;
  cursor: pointer;
}
.progress-bar__fill {
  height: 100%;
  width: 35%;
  background: #E0E0E0;
  border-radius: 10rem;
  position: relative;
}
.progress-bar__fill::after {
  content: "";
  position: absolute;
  right: -0.55rem;
  top: 50%;
  transform: translateY(-50%);
  width: 1.1rem;
  height: 1.1rem;
  background: white;
  border-radius: 50%;
}
@media (max-width: 767px) {
  .progress-bar__fill::after {
    opacity: 1;
  }
}
@media (min-width: 768px) {
  .progress-bar__fill::after {
    opacity: 0;
    transition: opacity 0.2s;
  }
}
@media (min-width: 768px) {
  .progress-bar:hover .progress-bar__fill::after {
    opacity: 1;
  }
}

.progress-times {
  display: flex;
  justify-content: space-between;
  margin-top: 0.6rem;
}

.track-time {
  font-size: 0.85rem;
  color: #b3b3b3;
}

.player-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 2.4rem;
}
.player-row .player__btn {
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
}
.player-row .player__btn img {
  width: 4rem;
  height: 4rem;
  display: block;
}
.player-row .player__btn--play img {
  width: 5.6rem;
  height: 5.6rem;
  background: white;
  border-radius: 50%;
  padding: 0.6rem;
  filter: invert(1);
}

.mobile-bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 2.4rem;
  padding-bottom: 1rem;
}
.mobile-bottom-bar .icon-btn img {
  width: 3rem;
  height: 3rem;
  display: block;
  opacity: 0.7;
}

.icon-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}

button {
  background-color: transparent;
  border: none;
  display: flex;
  align-items: center;
}

.control-bar {
  grid-area: control-bar;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.8rem;
  padding-bottom: 1.6rem;
  cursor: pointer;
  background-color: #333842;
  border-radius: 1rem;
  position: sticky;
  z-index: 100;
  bottom: 9.5rem;
  width: 97vw;
  justify-self: center;
  margin: 0 5px;
}
@media (min-width: 500px) {
  .control-bar {
    position: sticky;
    padding: 2rem;
    margin: 0;
    width: 97.5%;
    bottom: 0;
  }
}

.progress-bar {
  flex: 1;
  height: 0.4rem;
  background: #555;
  border-radius: 10rem;
  position: relative;
  cursor: pointer;
}
.progress-bar--mobile {
  position: absolute;
  bottom: 0.1rem;
  left: 0.9rem;
  right: 0.9rem;
  height: 0.3rem;
  width: 96%;
}
@media (min-width: 500px) {
  .progress-bar--mobile {
    display: none;
  }
}
.progress-bar__fill {
  height: 100%;
  width: 35%;
  background: #E0E0E0;
  border-radius: 10rem;
  position: relative;
}
.progress-bar__fill::after {
  content: "";
  position: absolute;
  right: -0.5rem;
  top: 50%;
  transform: translateY(-50%);
  width: 1rem;
  height: 1rem;
  background: white;
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.2s;
}
.progress-bar:hover .progress-bar__fill::after {
  opacity: 1;
}

.control-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.player {
  display: flex;
  gap: 0.5rem;
}
.player button {
  display: none;
}
@media (min-width: 500px) {
  .player button {
    display: flex;
  }
  .player .player__pause {
    display: flex;
  }
}

.player__progress {
  display: none;
}
@media (min-width: 500px) {
  .player__progress {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    padding: 0 1rem;
  }
}

.control-right {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.control-right .global .player__btn.add-btn {
  display: flex;
}
.control-right .global .player__btn {
  display: none;
}
.control-right .additions {
  display: none;
}
@media (min-width: 500px) {
  .control-right .global .player__btn {
    display: flex;
  }
  .control-right .additions {
    display: flex;
    gap: 1rem;
  }
}

.track-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-right: auto;
}
@media (min-width: 500px) {
  .track-meta {
    flex: 1;
  }
}

.track-time {
  display: none;
}
@media (min-width: 500px) {
  .track-time {
    display: block;
    color: #898989;
    font-size: 1.2rem;
  }
}

.track-info {
  display: flex;
  flex-direction: column;
}
.track-info-title, .track-info-singer, .track-info-album {
  font-size: 1.4rem;
  font-weight: 400;
  letter-spacing: 3%;
  color: #E0E0E0;
  padding-bottom: 2px;
}
.track-info-singer, .track-info-album {
  color: #898989;
}
.track-info-album {
  display: none;
}
@media (min-width: 500px) {
  .track-info-album {
    display: block;
  }
}

.track-picture {
  width: 4rem;
  height: 4rem;
  flex-shrink: 0;
}
@media (min-width: 500px) {
  .track-picture {
    width: 5.1rem;
    height: 5.1rem;
  }
}
.track-picture img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0.4rem;
}

.global {
  display: flex;
  margin-right: 0;
}
@media (min-width: 500px) {
  .global {
    border-right: 0.1rem solid #898989;
    margin-right: 1.5rem;
  }
}

.additions {
  display: none;
}
@media (min-width: 500px) {
  .additions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
}

.player__ai {
  display: none;
}
@media (min-width: 500px) {
  .player__ai {
    display: flex;
    width: 4rem;
    flex-shrink: 0;
  }
  .player__ai img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }
}

.add-btn {
  display: inline-block;
}

.responsive-play-btn {
  display: inline-block;
}
@media (min-width: 500px) {
  .responsive-play-btn {
    display: none;
  }
}

body {
  overflow-x: hidden;
  background-color: black;
  margin: 0;
  display: grid;
  grid-template-areas: "header" "main" "control-bar";
  grid-template-columns: 1fr;
  grid-template-rows: auto 1fr auto;
  height: 100dvh;
  background-color: #060606;
}
@media (min-width: 500px) {
  body {
    grid-template-areas: "sidebar header" "sidebar main" "sidebar control-bar";
    grid-template-columns: 25.9rem 1fr;
    grid-template-rows: 5.4rem 1fr #333842;
    height: 100vh;
    overflow: hidden;
  }
}

main {
  grid-area: main;
}
@media (min-width: 500px) {
  main {
    overflow-y: auto;
    border: 1px solid #202020;
    border-radius: 10px;
    margin-bottom: 5px;
  }
}

/*# sourceMappingURL=style.csss.map */
