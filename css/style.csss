@charset "UTF-8";
html, body, div, span, applet, object, iframe,
h1, h2, h3, h4, h5, h6, p, blockquote, pre,
a, abbr, acronym, address, big, cite, code,
del, dfn, em, img, ins, kbd, q, s, samp,
small, strike, strong, sub, sup, tt, var,
b, u, i, center,
dl, dt, dd, ol, ul, li,
fieldset, form, label, legend,
table, caption, tbody, tfoot, thead, tr, th, td,
article, aside, canvas, details, embed,
figure, figcaption, footer, header, hgroup,
menu, nav, output, ruby, section, summary,
time, mark, audio, video {
  margin: 0;
  padding: 0;
  border: 0;
  font-size: 100%;
  font: inherit;
  vertical-align: baseline;
}

/* HTML5 display-role reset for older browsers */
article, aside, details, figcaption, figure,
footer, header, hgroup, menu, nav, section {
  display: block;
}

body {
  line-height: 1;
  font-family: "Satoshi";
}

ol, ul {
  list-style: none;
}

blockquote, q {
  quotes: none;
}

blockquote:before, blockquote:after,
q:before, q:after {
  content: "";
  content: none;
}

table {
  border-collapse: collapse;
  border-spacing: 0;
}

html {
  font-size: 62.5%;
}

.header-desctop {
  display: none;
}
@media (min-width: 500px) {
  .header-desctop {
    display: flex;
    justify-content: space-between;
    padding: 3px;
    background-color: #060606;
    width: calc(100vw - 28.9rem);
  }
}

.header-mobile {
  position: fixed;
  bottom: 0;
  padding-top: 1.6rem;
  padding-bottom: 2.4rem;
  display: flex;
  width: 100vw;
  justify-content: center;
  z-index: 100;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.85) 0%, #111111 62%);
}
@media (min-width: 500px) {
  .header-mobile {
    display: none;
  }
}

.header-nav {
  display: flex;
}
.header-nav ul {
  display: flex;
  column-gap: 2.1rem;
}
.header-nav button {
  display: flex;
  flex-direction: column;
  justify-content: center;
  row-gap: 1.059rem;
  height: 5.5rem;
  width: fit-content;
  font-size: 1.2rem;
  color: #898989;
  background-color: transparent;
  border: none;
}
.header-nav button img {
  height: 1.8574rem;
}

@media (min-width: 500px) {
  .header-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .header-nav ul {
    display: flex;
    justify-content: center;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 1rem;
  }
  .header-nav li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-items: center;
    width: 100%;
    border-radius: 1rem;
    flex: none;
    transition: all 0.3s ease;
    cursor: pointer;
    max-width: 26rem;
  }
  .header-nav li:hover {
    background-color: rgba(32, 32, 32, 0.5019607843);
    color: #E0E0E0;
  }
  .header-nav li:hover .sidebar-arrow {
    color: #E0E0E0;
  }
  .header-nav li:hover .icon img {
    border-color: #E0E0E0;
  }
  .header-nav li .sidebar-item {
    border: none;
    font: inherit;
    color: inherit;
    cursor: pointer;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    height: 100%;
  }
  .header-nav li .icon {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 4.04rem;
    height: 4.04rem;
    border-radius: 0.2rem;
    flex: none;
  }
  .header-nav li .icon img {
    width: 1.92rem;
    height: 1.92rem;
  }
  .header-nav li .item-label {
    font-size: 1.4rem;
    line-height: 100%;
    letter-spacing: 3%;
  }
  .header-nav li {
    width: 21rem;
    height: 4.04rem;
  }
  .header-nav li.active {
    background-color: rgba(32, 32, 32, 0.5019607843);
  }
  .header-nav li.active button {
    color: #E0E0E0;
  }
  .header-nav li button {
    display: flex;
    justify-content: left;
    flex-direction: row;
    width: 100%;
    height: 100%;
    padding: 0.7rem 1.5rem;
    cursor: pointer;
    color: #898989;
    background: transparent;
    border: none;
  }
  .header-nav li button:hover {
    color: #E0E0E0;
  }
}

@media (min-width: 500px) {
  .search-container {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-container input {
    padding: 1.2rem 1.2rem 1.2rem 5rem;
    font-size: 1.4rem;
    width: 35rem;
    color: #898989;
    border: none;
    background-color: #060606;
    border-radius: 1rem;
  }
  .search-container img {
    position: absolute;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.92rem;
    height: 1.92rem;
  }
}

@media (min-width: 500px) {
  .header-action-icons {
    padding: 6.79px 0;
  }
  .header-action-icons ul {
    display: flex;
    align-items: center;
    column-gap: 1.3rem;
  }
  .header-action-icons li {
    cursor: pointer;
  }
}

.sidebar {
  grid-area: sidebar;
  display: none;
}
@media (min-width: 500px) {
  .sidebar {
    display: flex;
    flex-direction: column;
    background-color: #060606;
    color: #898989;
    height: 100vh;
    width: 25.9rem;
    padding: 1.1rem;
    top: 0;
    box-sizing: border-box;
    width: 100%;
    padding: 1.1rem;
    height: 100vh;
  }
}
@media (min-width: 500px) and (min-width: 500px) {
  .sidebar .sidebar__library-btn {
    height: 5.4rem;
    display: flex;
    align-items: center;
    width: 100%;
  }
}
@media (min-width: 500px) {
  .sidebar .sidebar-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.1rem;
    list-style: none;
    padding: 0;
    width: 100%;
  }
  .sidebar .sidebar-content li:first-child {
    margin-top: -0.4rem;
  }
}

.sidebar-items {
  display: flex;
  justify-content: space-between;
  align-items: center;
  align-items: center;
  width: 100%;
  border-radius: 1rem;
  flex: none;
  transition: all 0.3s ease;
  cursor: pointer;
  max-width: 26rem;
}
.sidebar-items:hover {
  background-color: rgba(32, 32, 32, 0.5019607843);
  color: #E0E0E0;
}
.sidebar-items:hover .sidebar-arrow {
  color: #E0E0E0;
}
.sidebar-items:hover .icon img {
  border-color: #E0E0E0;
}
.sidebar-items .sidebar-item {
  border: none;
  font: inherit;
  color: inherit;
  cursor: pointer;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 1rem;
  height: 100%;
}
.sidebar-items .icon {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 4.04rem;
  height: 4.04rem;
  border-radius: 0.2rem;
  flex: none;
}
.sidebar-items .icon img {
  width: 1.92rem;
  height: 1.92rem;
}
.sidebar-items .item-label {
  font-size: 1.4rem;
  line-height: 100%;
  letter-spacing: 3%;
}
.sidebar-items .sidebar-arrow {
  width: 4rem;
  height: 4rem;
  flex: none;
  color: #898989;
  margin-left: auto;
}

.main {
  padding: 1.2rem 2.5rem 0 2.5rem;
}

@media (min-width: 500px) {
  .main {
    border: 0.1rem solid rgba(32, 32, 32, 0.5019607843);
    border-radius: 1rem;
    padding: 1.2rem 2.5rem 0 2.5rem;
  }
}

.music-audio-filter {
  display: flex;
  justify-content: space-between;
  margin-bottom: 2.2rem;
  padding-right: 1rem;
}
.music-audio-filter ul {
  display: flex;
  column-gap: 1rem;
}
.music-audio-filter li button {
  display: flex;
  color: #E0E0E0;
  background-color: #202020;
  border: none;
  font-size: 1.4rem;
  font-weight: 700;
  padding: 0.8rem 1.5rem;
  border-radius: 0.8rem;
  font-size: 12px;
  font-weight: 400;
}
.music-audio-filter li:first-child button {
  display: none;
}

@media (min-width: 500px) {
  .music-audio-filter {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.6rem;
  }
  .music-audio-filter ul {
    display: flex;
    column-gap: 1rem;
  }
  .music-audio-filter ul button {
    display: flex;
    color: #E0E0E0;
    background-color: #202020;
    border: none;
    font-size: 1.4rem;
    font-weight: 700;
    padding: 0.8rem 1.5rem;
    border-radius: 0.8rem;
  }
  .music-audio-filter ul li:first-child button {
    background-color: #E0E0E0;
    color: #111111;
  }
}

.mobile-insta-access-music-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;
}

@media (min-width: 500px) {
  .mobile-insta-access-music-list {
    display: none;
  }
}

.mobile-insta-access-container {
  display: flex;
  background-color: #202020;
  padding: 0.8rem;
  width: 44%;
  border-radius: 1rem;
}
.mobile-insta-access-container div {
  display: flex;
  flex-direction: column;
  justify-content: center;
  row-gap: 0.1rem;
  min-width: 0;
  padding-left: 0.8rem;
}
.mobile-insta-access-container img {
  height: 4.3rem;
  border-radius: 3px;
}

.mobile-insta-access-container h4 {
  color: #E0E0E0;
  font-size: 1.4rem;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mobile-insta-access-container p {
  color: #898989;
  font-size: 1.4rem;
  font-weight: 400;
}

.card-list-header {
  padding-bottom: 1.5rem;
  display: flex;
  justify-content: space-between;
  margin-top: 30px;
}
.card-list-header h2 {
  color: #E0E0E0;
  font-size: 2rem;
  font-weight: 700;
}
.card-list-header img:nth-child(1),
.card-list-header img:nth-child(2) {
  display: none;
}

@media (min-width: 500px) {
  .card-list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-list-header img {
    display: flex;
  }
  .card-list-header h2 {
    color: #E0E0E0;
    font-size: 2rem;
    font-weight: 700;
  }
  .card-list-header div {
    display: flex;
    align-items: center;
  }
  .card-list-header img:nth-child(1),
  .card-list-header img:nth-child(2) {
    display: flex;
  }
}

